generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Auth & Users

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  passwordHash      String?
  name              String?
  avatar            String?
  country           String?
  role              Role      @default(BUYER)
  bannedAt          DateTime?
  banReason         String?
  twoFactorSecret   String?
  verificationLevel String    @default("UNVERIFIED")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions                Session[]
  accounts                Account[]
  addresses               Address[]
  orders                  Order[]
  notifications           Notification[]
  couponRedemptions       CouponRedemption[]
  submissions             CardSubmission[]
  wishlists               Wishlist[]
  notificationEvents      NotificationEvent[]
  notificationPreferences NotificationPreference[]

  // Marketplace relations
  sellerProfile        SellerProfile?
  buyerOffers          Offer[]         @relation("BuyerOffers")
  buyerConversations   Conversation[]  @relation("BuyerConversations")
  sellerConversations  Conversation[]  @relation("SellerConversations")
  sentMessages         Message[]
  reviewsGiven         Review[]        @relation("ReviewsGiven")
  reviewsReceived      Review[]        @relation("ReviewsReceived")
  disputesFiled        Dispute[]
  savedSearches        SavedSearch[]

  // Phase 4 relations
  raffleTickets        RaffleTicket[]
  rafflePurchases      RafflePurchase[]
  raffleWins           Raffle[]            @relation("RaffleWinner")
  mysteryPurchases     MysteryPurchase[]
  mysteryPulls         MysteryPull[]
  ticketReservations   TicketReservation[]

  // Phase 5 relations
  userBadges           UserBadge[]
  follows              SellerFollow[] @relation("UserFollows")
  listingLikes         ListingLike[]  @relation("UserLikes")

  @@map("users")
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  device       String?
  ip           String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Address {
  id         String      @id @default(cuid())
  userId     String
  type       AddressType
  fullName   String
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String
  country    String
  phone      String?
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingOrders  Order[] @relation("ShippingAddress")
  billingOrders   Order[] @relation("BillingAddress")

  @@map("addresses")
}

enum AddressType {
  SHIPPING
  BILLING
}

// Card Reference

model Card {
  id                 String    @id @default(cuid())
  tcgPlayerProductId String?   @unique
  name               String
  setName            String
  cardNumber         String
  rarity             String?
  language           String    @default("English")
  printing           String?
  imageUrl           String?
  normalizedName     String
  tcgPriceNM         Float?
  tcgPriceLP         Float?
  tcgPriceMP         Float?
  tcgPriceHP         Float?
  tcgPriceMarket     Float?
  tcgPriceUpdatedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  products     Product[]
  priceHistory CardPriceHistory[]
  submissions  CardSubmission[]
  wishlists    Wishlist[]
  listings     Listing[]

  @@index([normalizedName])
  @@index([setName])
  @@map("cards")
}

model CardPriceHistory {
  id          String   @id @default(cuid())
  cardId      String
  source      String   @default("tcgplayer")
  currency    String   @default("USD")
  nmPrice     Float?
  lpPrice     Float?
  mpPrice     Float?
  hpPrice     Float?
  marketPrice Float?
  fetchedAt   DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, fetchedAt])
  @@map("card_price_history")
}

// Products

model Product {
  id             String          @id @default(cuid())
  cardId         String?
  name           String
  slug           String          @unique
  category       ProductCategory
  description    String?         @db.Text
  images         String[]
  price          Float
  compareAtPrice Float?
  stock          Int             @default(0)
  condition      CardCondition?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  card       Card?            @relation(fields: [cardId], references: [id])
  variants   ProductVariant[]
  orderItems OrderItem[]
  wishlists  Wishlist[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

enum ProductCategory {
  PACK
  BOOSTER_BOX
  SLAB
  SINGLE
}

enum CardCondition {
  NM
  LP
  MP
  HP
}

model ProductVariant {
  id        String @id @default(cuid())
  productId String
  name      String
  price     Float
  stock     Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

// Orders & Payments

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  buyerId           String
  status            OrderStatus @default(PENDING)
  totalAmount       Float
  shippingCost      Float       @default(0)
  discountAmount    Float       @default(0)
  shippingAddressId String?
  billingAddressId  String?
  notes             String?
  type              String      @default("STORE")
  commission        Float       @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  buyer           User                @relation(fields: [buyerId], references: [id])
  shippingAddress Address?            @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddress  Address?            @relation("BillingAddress", fields: [billingAddressId], references: [id])
  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]
  escrow          EscrowTransaction?
  reviews         Review[]
  dispute         Dispute?

  @@index([buyerId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  RETURNED
  REFUNDED
  CANCELLED
}

model OrderItem {
  id                String         @id @default(cuid())
  orderId           String
  productId         String?
  listingId         String?
  sellerId          String?
  quantity          Int
  priceAtPurchase   Float
  titleSnapshot     String
  imageSnapshot     String?
  conditionSnapshot CardCondition?
  skuSnapshot       String?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])

  @@map("order_items")
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider
  providerPaymentId String?         @unique
  amount            Float
  currency          String          @default("USD")
  status            PaymentStatus   @default(INITIATED)
  capturedAt        DateTime?
  refundedAmount    Float           @default(0)
  idempotencyKey    String?         @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payments")
}

enum PaymentProvider {
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  CONFIRMED
  FAILED
  VOIDED
  REFUNDED
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  carrier        String?
  service        String?
  trackingNumber String?
  labelUrl       String?
  status         ShipmentStatus @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("shipments")
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

// Coupons

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Float
  usageLimit Int?
  usageCount Int        @default(0)
  minOrder   Float?
  startsAt   DateTime   @default(now())
  endsAt     DateTime?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())

  redemptions CouponRedemption[]

  @@map("coupons")
}

enum CouponType {
  PERCENTAGE
  FIXED
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  userId     String
  orderId    String?
  redeemedAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
  @@map("coupon_redemptions")
}

// Notifications

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  ORDER_CONFIRMED
  ORDER_SHIPPED
  ORDER_DELIVERED
  SECURITY_ALERT
  SYSTEM
}

// Site Settings (key-value store for admin-managed config)

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// Admin

model AuditLog {
  id         String    @id @default(cuid())
  actorType  ActorType
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  details    Json?
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum ActorType {
  ADMIN
  SYSTEM
  USER
  WEBHOOK
}

// ──────────────────────────────────────
// Buy Cards Program
// ──────────────────────────────────────

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  OFFER_SENT
  ACCEPTED
  REJECTED
  SHIPPING
  RECEIVED
  COMPLETED
}

model CardSubmission {
  id                 String           @id @default(cuid())
  userId             String
  cardId             String?
  images             String[]
  description        String?          @db.Text
  estimatedCondition CardCondition
  tcgPriceNM         Float?
  tcgPriceLP         Float?
  tcgPriceMP         Float?
  tcgPriceHP         Float?
  offeredPrice       Float?
  counterOfferPrice  Float?
  finalAcceptedPrice Float?
  status             SubmissionStatus @default(SUBMITTED)
  assignedAdminId    String?
  offerExpiresAt     DateTime?
  shippingStatus     String?
  receivedAt         DateTime?
  completedAt        DateTime?
  discordMessageId   String?
  discordThreadId    String?
  adminNotes         String?          @db.Text
  rejectionReason    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user   User  @relation(fields: [userId], references: [id])
  card   Card? @relation(fields: [cardId], references: [id])
  events CardSubmissionEvent[]

  @@index([userId])
  @@index([status])
  @@index([assignedAdminId])
  @@map("card_submissions")
}

model CardSubmissionEvent {
  id           String   @id @default(cuid())
  submissionId String
  actorId      String?
  type         String
  payload      Json?
  createdAt    DateTime @default(now())

  submission CardSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("card_submission_events")
}

// ──────────────────────────────────────
// Wishlist
// ──────────────────────────────────────

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  productId   String?
  cardId      String?
  priceAtAdd  Float?
  alertOnDrop Boolean  @default(true)
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  card    Card?    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([userId, cardId])
  @@index([userId])
  @@map("wishlists")
}

// ──────────────────────────────────────
// Enhanced Notifications
// ──────────────────────────────────────

model NotificationEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId])
  @@index([type])
  @@map("notification_events")
}

enum DeliveryChannel {
  IN_APP
  EMAIL
  DISCORD
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  FAILED
}

model NotificationDelivery {
  id         String          @id @default(cuid())
  eventId    String
  channel    DeliveryChannel
  status     DeliveryStatus  @default(PENDING)
  sentAt     DateTime?
  error      String?
  retryCount Int             @default(0)
  createdAt  DateTime        @default(now())

  event NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([channel, status])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id        String          @id @default(cuid())
  userId    String
  eventType String
  channel   DeliveryChannel
  enabled   Boolean         @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType, channel])
  @@map("notification_preferences")
}

// ──────────────────────────────────────
// Search Analytics
// ──────────────────────────────────────

model SearchAnalytics {
  id                String   @id @default(cuid())
  userId            String?
  query             String
  normalizedQuery   String
  filtersJson       Json?
  resultCount       Int
  clickedEntityId   String?
  clickedEntityType String?
  sessionId         String?
  createdAt         DateTime @default(now())

  @@index([normalizedQuery])
  @@index([createdAt])
  @@map("search_analytics")
}

// ──────────────────────────────────────
// Marketplace — Phase 3
// ──────────────────────────────────────

enum ListingModerationStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ListingSaleStatus {
  INACTIVE
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
}

enum EscrowStatus {
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ReviewType {
  BUYER_TO_SELLER
  SELLER_TO_BUYER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  ESCALATED
}

model CommissionTier {
  id       String @id @default(cuid())
  name     String @unique
  minSales Int
  rate     Float

  sellers SellerProfile[]

  @@map("commission_tiers")
}

model SellerProfile {
  id                 String    @id @default(cuid())
  userId             String    @unique
  stripeConnectId    String?
  paypalEmail        String?
  tierId             String?
  tierAssignedAt     DateTime?
  tierOverrideReason String?
  totalSales         Int       @default(0)
  rating             Float?
  ratingCount        Int       @default(0)
  bio                String?   @db.Text
  responseTime       Int?
  location           String?
  isVerified         Boolean   @default(false)
  isFeatured         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      CommissionTier? @relation(fields: [tierId], references: [id])
  listings  Listing[]
  payouts   Payout[]
  followers SellerFollow[]

  @@map("seller_profiles")
}

model Listing {
  id                          String                   @id @default(cuid())
  sellerId                    String
  cardId                      String?
  title                       String
  description                 String?                  @db.Text
  images                      String[]
  price                       Float
  suggestedPrice              Float?
  dealScore                   Float?
  dealScoreBand               String?
  marketPriceSourceUpdatedAt  DateTime?
  condition                   CardCondition?
  grade                       Float?
  gradingCompany              String?
  category                    ProductCategory
  moderationStatus            ListingModerationStatus  @default(DRAFT)
  saleStatus                  ListingSaleStatus        @default(INACTIVE)
  moderationNote              String?
  shipsToCountries            String[]
  viewCount                   Int                      @default(0)
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  seller        SellerProfile @relation(fields: [sellerId], references: [id])
  card          Card?         @relation(fields: [cardId], references: [id])
  offers        Offer[]
  conversations Conversation[]
  orderItems    OrderItem[]
  likes         ListingLike[]

  @@index([sellerId])
  @@index([saleStatus])
  @@index([moderationStatus])
  @@index([category])
  @@map("listings")
}

model Offer {
  id        String      @id @default(cuid())
  listingId String
  buyerId   String
  amount    Float
  message   String?
  status    OfferStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  listing Listing      @relation(fields: [listingId], references: [id])
  buyer   User         @relation("BuyerOffers", fields: [buyerId], references: [id])
  events  OfferEvent[]

  @@index([listingId])
  @@index([buyerId])
  @@map("offers")
}

model OfferEvent {
  id        String   @id @default(cuid())
  offerId   String
  actorId   String
  type      String
  amount    Float?
  message   String?
  createdAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@map("offer_events")
}

model EscrowTransaction {
  id                    String       @id @default(cuid())
  orderId               String       @unique
  amount                Float
  status                EscrowStatus @default(HELD)
  stripePaymentIntentId String?      @unique
  releasedAt            DateTime?
  createdAt             DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@map("escrow_transactions")
}

model Payout {
  id               String       @id @default(cuid())
  sellerId         String
  orderId          String?
  grossAmount      Float
  fee              Float
  netAmount        Float
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?      @unique
  createdAt        DateTime     @default(now())

  seller SellerProfile @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@map("payouts")
}

model Conversation {
  id            String   @id @default(cuid())
  listingId     String?
  buyerId       String
  sellerId      String
  lastMessageAt DateTime
  createdAt     DateTime @default(now())

  listing  Listing?  @relation(fields: [listingId], references: [id])
  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  seller   User      @relation("SellerConversations", fields: [sellerId], references: [id])
  messages Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

model Review {
  id               String           @id @default(cuid())
  orderId          String
  reviewerId       String
  revieweeId       String
  rating           Int
  comment          String?          @db.Text
  type             ReviewType
  isVisible        Boolean          @default(true)
  moderationStatus ModerationStatus @default(PENDING)
  createdAt        DateTime         @default(now())

  order    Order @relation(fields: [orderId], references: [id])
  reviewer User  @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User  @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([orderId, type])
  @@index([revieweeId])
  @@map("reviews")
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String        @unique
  filedBy     String
  reason      String        @db.Text
  evidence    String[]
  status      DisputeStatus @default(OPEN)
  adminNotes  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  filer User  @relation(fields: [filedBy], references: [id])

  @@index([status])
  @@map("disputes")
}

model SavedSearch {
  id                String   @id @default(cuid())
  userId            String
  query             String
  filtersJson       Json?
  alertOnNewResults Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_searches")
}

// ──────────────────────────────────────
// Phase 4 — Raffle
// ──────────────────────────────────────

enum RaffleStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  FROZEN
  DRAWING
  COMPLETED
  CANCELLED
  PRIZE_SHIPPED
}

enum ReservationStatus {
  RESERVED
  CONFIRMED
  EXPIRED
  VOIDED
}

enum RafflePurchaseStatus {
  INITIATED
  AUTHORIZED
  CONFIRMED
  FAILED
  VOIDED
  REFUNDED
}

enum VisibilityMode {
  PUBLIC_NAMES
  PARTIAL
  ANONYMOUS
}

model Raffle {
  id                     String         @id @default(cuid())
  title                  String
  description            String?        @db.Text
  prizeImages            String[]
  prizeValue             Float
  ticketPrice            Float
  totalSlots             Int
  filledSlots            Int            @default(0)
  maxTicketsPerUser      Int            @default(1)
  minFillThreshold       Float          @default(0.5)
  status                 RaffleStatus   @default(DRAFT)
  drawMethod             String?
  winnerId               String?
  winningTicketNumber    Int?
  drawnAt                DateTime?
  randomSeed             String?
  drawReference          String?
  legalRegionRestriction String?
  publishedTermsVersion  String?
  visibilityMode         VisibilityMode @default(PUBLIC_NAMES)
  cancelReason           String?
  prizeOrderId           String?
  startsAt               DateTime
  endsAt                 DateTime
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  tickets      RaffleTicket[]
  purchases    RafflePurchase[]
  reservations TicketReservation[]
  winner       User?              @relation("RaffleWinner", fields: [winnerId], references: [id])

  @@index([status])
  @@map("raffles")
}

model RafflePurchase {
  id        String               @id @default(cuid())
  raffleId  String
  userId    String
  quantity  Int
  amount    Float
  paymentId String?
  status    RafflePurchaseStatus @default(INITIATED)
  createdAt DateTime             @default(now())

  raffle  Raffle         @relation(fields: [raffleId], references: [id])
  user    User           @relation(fields: [userId], references: [id])
  tickets RaffleTicket[]

  @@index([raffleId])
  @@index([userId])
  @@map("raffle_purchases")
}

model RaffleTicket {
  id           String   @id @default(cuid())
  raffleId     String
  purchaseId   String
  userId       String
  ticketNumber Int
  assignedAt   DateTime @default(now())

  raffle   Raffle         @relation(fields: [raffleId], references: [id])
  purchase RafflePurchase @relation(fields: [purchaseId], references: [id])
  user     User           @relation(fields: [userId], references: [id])

  @@unique([raffleId, ticketNumber])
  @@index([userId])
  @@map("raffle_tickets")
}

model TicketReservation {
  id        String            @id @default(cuid())
  raffleId  String
  userId    String
  quantity  Int
  status    ReservationStatus @default(RESERVED)
  expiresAt DateTime
  createdAt DateTime          @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([raffleId])
  @@index([userId])
  @@map("ticket_reservations")
}

// ──────────────────────────────────────
// Phase 4 — Mystery Collection
// ──────────────────────────────────────

enum MysteryCollectionStatus {
  DRAFT
  ACTIVE
  LOW_STOCK
  SOLD_OUT
  ARCHIVED
}

enum MysteryPurchaseStatus {
  INITIATED
  CONFIRMED
  FAILED
  REFUNDED
}

model MysteryCollection {
  id               String    @id @default(cuid())
  name             String
  tier             String
  price            Float
  currentVersionId String?
  isActive         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  versions  MysteryCollectionVersion[]
  purchases MysteryPurchase[]

  @@map("mystery_collections")
}

model MysteryCollectionVersion {
  id                 String                  @id @default(cuid())
  collectionId       String
  version            Int
  pullRates          Json
  guaranteedMinValue Float
  valueLockedAt      DateTime?
  stockRemaining     Int                     @default(0)
  status             MysteryCollectionStatus @default(DRAFT)
  effectiveFrom      DateTime?
  activatedBy        String?
  createdAt          DateTime                @default(now())

  collection MysteryCollection @relation(fields: [collectionId], references: [id])
  poolItems  MysteryPoolItem[]
  pulls      MysteryPull[]
  purchases  MysteryPurchase[]

  @@index([collectionId])
  @@map("mystery_collection_versions")
}

model MysteryPoolItem {
  id          String  @id @default(cuid())
  versionId   String
  productId   String?
  cardId      String?
  tierName    String
  weight      Float
  quantity    Int
  lockedValue Float

  version MysteryCollectionVersion @relation(fields: [versionId], references: [id])

  @@index([versionId])
  @@map("mystery_pool_items")
}

model MysteryPurchase {
  id           String                @id @default(cuid())
  userId       String
  collectionId String
  versionId    String
  amount       Float
  paymentId    String?
  status       MysteryPurchaseStatus @default(INITIATED)
  pricePaid    Float
  createdAt    DateTime              @default(now())

  user       User                     @relation(fields: [userId], references: [id])
  collection MysteryCollection        @relation(fields: [collectionId], references: [id])
  version    MysteryCollectionVersion @relation(fields: [versionId], references: [id])
  pull       MysteryPull?

  @@index([userId])
  @@index([collectionId])
  @@map("mystery_purchases")
}

model MysteryPull {
  id                 String   @id @default(cuid())
  purchaseId         String   @unique
  collectionId       String
  versionId          String
  userId             String
  tierRolled         String
  poolItemId         String
  revealedItemName   String
  revealedItemImage  String?
  revealedItemValue  Float
  pulledAt           DateTime @default(now())

  purchase MysteryPurchase          @relation(fields: [purchaseId], references: [id])
  version  MysteryCollectionVersion @relation(fields: [versionId], references: [id])
  user     User                     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("mystery_pulls")
}

// ──────────────────────────────────────
// Phase 4 — Live Support Chat
// ──────────────────────────────────────

enum SupportConversationStatus {
  OPEN
  WAITING_ON_CUSTOMER
  WAITING_ON_AGENT
  RESOLVED
  CLOSED
}

enum SupportPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportSenderType {
  CUSTOMER
  AGENT
  SYSTEM
  BOT
}

enum SupportMessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM_MSG
  AUTO_REPLY
}

model SupportConversation {
  id                   String                    @id @default(cuid())
  userId               String?
  visitorId            String?
  assignedAgentId      String?
  status               SupportConversationStatus @default(OPEN)
  priority             SupportPriority           @default(NORMAL)
  priorityReason       String?
  routingReason        String?
  category             String?
  tags                 String[]
  subject              String?
  sourcePageUrl        String?
  sourceType           String?
  lastMessageAt        DateTime?
  lastCustomerMessageAt DateTime?
  lastAgentMessageAt   DateTime?
  botResolvedAt        DateTime?
  startedAt            DateTime                  @default(now())
  resolvedAt           DateTime?
  closedReason         String?
  satisfactionRating   Int?
  csatComment          String?

  messages       SupportMessage[]
  internalNotes  SupportInternalNote[]
  transfers      SupportTransferLog[]

  @@index([status])
  @@index([userId])
  @@map("support_conversations")
}

model SupportMessage {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String?
  senderType     SupportSenderType
  messageType    SupportMessageType @default(TEXT)
  content        String             @db.Text
  attachments    String[]
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  metadataJson   Json?
  createdAt      DateTime           @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("support_messages")
}

model SupportInternalNote {
  id             String   @id @default(cuid())
  conversationId String
  agentId        String
  content        String   @db.Text
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("support_internal_notes")
}

model SupportTransferLog {
  id             String   @id @default(cuid())
  conversationId String
  fromAgentId    String
  toAgentId      String
  reason         String?
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("support_transfer_logs")
}

model CannedResponse {
  id        String   @id @default(cuid())
  shortcut  String   @unique
  title     String
  content   String   @db.Text
  category  String?
  createdBy String?
  createdAt DateTime @default(now())

  @@map("canned_responses")
}

// ──────────────────────────────────────
// Phase 5 — Badges
// ──────────────────────────────────────

enum BadgeCategory {
  TRUST
  PERFORMANCE
  MILESTONE
  COMMUNITY
}

enum BadgeMode {
  PERMANENT
  DYNAMIC
  TIME_BOUND
}

enum BadgeVisibility {
  PUBLIC
  INTERNAL
}

model Badge {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String
  icon            String?
  category        BadgeCategory
  badgeMode       BadgeMode
  displayPriority Int             @default(100)
  visibility      BadgeVisibility @default(PUBLIC)
  criteria        Json?
  groupKey        String?
  isAutoAwarded   Boolean         @default(true)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())

  userBadges UserBadge[]

  @@index([category])
  @@index([badgeMode])
  @@map("badges")
}

model UserBadge {
  id              String    @id @default(cuid())
  userId          String
  badgeId         String
  awardedAt       DateTime  @default(now())
  awardedContext  Json?
  lastEvaluatedAt DateTime?
  expiresAt       DateTime?
  isRevoked       Boolean   @default(false)
  revokedAt       DateTime?
  revokedReason   String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ──────────────────────────────────────
// Email Marketing Signups
// ──────────────────────────────────────

model EmailSubscription {
  id         String   @id @default(cuid())
  email      String   @unique
  couponCode String?
  claimedAt  DateTime @default(now())
  source     String?
  createdAt  DateTime @default(now())

  @@index([email])
  @@map("email_subscriptions")
}

// ──────────────────────────────────────
// Homepage Hero Carousel (admin-managed)
// ──────────────────────────────────────

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String
  buttonLabel String
  buttonLink  String
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@map("hero_slides")
}

// ──────────────────────────────────────
// Homepage Category Tiles (admin-managed)
// ──────────────────────────────────────

model CategoryTile {
  id           String   @id @default(cuid())
  label        String
  imageUrl     String
  href         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, displayOrder])
  @@map("category_tiles")
}

// ──────────────────────────────────────
// Social: Following + Likes
// ──────────────────────────────────────

model SellerFollow {
  id              String   @id @default(cuid())
  followerId      String
  sellerProfileId String
  createdAt       DateTime @default(now())

  follower      User          @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@unique([followerId, sellerProfileId])
  @@index([followerId])
  @@index([sellerProfileId])
  @@map("seller_follows")
}

model ListingLike {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("listing_likes")
}
